{
  "app": { "id": "tracker", "name": "Tracker", "version": 1 },
  "entities": [
    { "id": "ent_item", "name": "item", "fields": [
      { "id": "fld_title", "name": "title", "type": "text", "required": true, "max": 200 },
      { "id": "fld_count", "name": "count", "type": "integer", "min": 0 },
      { "id": "fld_score", "name": "score", "type": "real" },
      { "id": "fld_active", "name": "active", "type": "boolean", "default": true },
      { "id": "fld_due", "name": "due", "type": "datetime" },
      { "id": "fld_kind", "name": "kind", "type": "enum", "values": ["a", "b", "c"], "default": "a" },
      { "id": "fld_parent", "name": "parent", "type": "reference", "target": "ent_item", "onDelete": "set_null" }
    ]}
  ]
}

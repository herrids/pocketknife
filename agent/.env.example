CLAUDE_CODE_OAUTH_TOKEN=

# VALIDATE_MODE=stub|http (default stub), SUBMIT_MODE=stub|http (default stub).
# http modes point at the real Go backend -- see seams/select.ts.
# SUBMIT_MODE=http posts the manifest + built dist/ to {GO_BASE_URL}/deploy
# (deployapi.NewServer() in the Go backend), which installs/activates the app
# live -- it is reachable at {GO_BASE_URL}/ui/<app_id>/ right after submit()
# returns. VALIDATE_MODE=http is not implemented yet.
# GO_BASE_URL=http://localhost:8080

# Optional: send a trace of every planner/builder step (model turns + tool
# calls) to Langfuse. Leave unset to run with tracing off.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketknife.local/manifest.schema.json",
  "title": "Pocketknife App Manifest",
  "description": "The canonical, declarative contract for a Pocketknife app. One immutable document per app version.",
  "type": "object",
  "additionalProperties": false,
  "required": ["app", "entities"],
  "properties": {
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "type": "string", "minLength": 1 },
        "emoji": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entity" }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "machineName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "fields"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "operations": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 1,
          "items": { "enum": ["create", "read", "update", "delete"] }
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["id", "name", "type"],
      "oneOf": [
        { "$ref": "#/$defs/field_text" },
        { "$ref": "#/$defs/field_integer" },
        { "$ref": "#/$defs/field_real" },
        { "$ref": "#/$defs/field_boolean" },
        { "$ref": "#/$defs/field_datetime" },
        { "$ref": "#/$defs/field_enum" },
        { "$ref": "#/$defs/field_reference" }
      ]
    },
    "field_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "text" },
        "required": { "type": "boolean" },
        "unique": { "type": "boolean" },
        "default": { "type": "string" },
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "field_integer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "integer" },
        "required": { "type": "boolean" },
        "unique": { "type": "boolean" },
        "default": { "type": "integer" },
        "min": { "type": "integer" },
        "max": { "type": "integer" }
      }
    },
    "field_real": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "real" },
        "required": { "type": "boolean" },
        "unique": { "type": "boolean" },
        "default": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "field_boolean": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "boolean" },
        "required": { "type": "boolean" },
        "default": { "type": "boolean" }
      }
    },
    "field_datetime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "datetime" },
        "required": { "type": "boolean" },
        "default": { "type": "string" }
      }
    },
    "field_enum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "values"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "enum" },
        "required": { "type": "boolean" },
        "default": { "type": "string" },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "field_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "target"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/machineName" },
        "type": { "const": "reference" },
        "required": { "type": "boolean" },
        "target": { "$ref": "#/$defs/stableId" },
        "onDelete": { "enum": ["set_null", "restrict", "cascade"] }
      }
    }
  }
}

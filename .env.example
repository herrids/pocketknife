# Single config file for the whole app: the Go server (cmd/pocketknife/main.go
# loads it via loadDotEnv) and the agent (agent/src/env.ts loads it the same
# way). Both loaders only fill vars not already set in the environment, so an
# explicit `FOO=bar ./pocketknife` always wins over this file. Missing file is
# fine -- config can come from the environment directly (systemd/docker/CI).

# Admin login for the shell (platform/auth.go). If POCKETKNIFE_ADMIN_PASSWORD
# is left unset, the server generates one and prints it (with the email) on
# boot -- fine for local dev, set both explicitly for anything longer-lived.
# POCKETKNIFE_ADMIN_EMAIL=admin@pocketknife.local
# POCKETKNIFE_ADMIN_PASSWORD=

# Required for the agent (planner/builder) to call Claude at all.
CLAUDE_CODE_OAUTH_TOKEN=

# VALIDATE_MODE=stub|http (default stub), SUBMIT_MODE=stub|http (default stub).
# http modes point at the real Go backend -- see agent/src/seams/select.ts.
# SUBMIT_MODE=http posts the manifest + built dist/ to {GO_BASE_URL}/deploy
# (deployapi.NewServer() in the Go backend), which installs/activates the app
# live -- it is reachable at {GO_BASE_URL}/ui/<app_id>/ right after submit()
# returns. VALIDATE_MODE=http is not implemented yet.
#
# GO_BASE_URL is NOT set here: when the Go server spawns the agent for the
# shell's "create app" flow (platform/plan.go), it injects GO_BASE_URL itself
# from its own -addr flag, so the two can never drift out of sync. It only
# needs to be set here for the standalone `npm run agent` CLI, if the backend
# isn't on the default localhost:8080.
# GO_BASE_URL=http://localhost:8080
SUBMIT_MODE=http

# Optional: send a trace of every planner/builder step (model turns + tool
# calls) to Langfuse. Leave unset to run with tracing off.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
